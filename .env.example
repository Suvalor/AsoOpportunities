# =============================================================================
# ASO 蓝海项目 — 环境变量示例（复制为 .env 后按需填写）
# =============================================================================

# ----- 多国家扫描（CLI 与 aso-service 共用，见 aso_core.scanner）-----
# 全量扫描国家列表，逗号分隔，顺序即扫描顺序
ASO_SCAN_COUNTRIES=us,gb,au,ca

# trend_gap 计算所用的对比国家（不含主市场，通常为主市场以外的区域）
ASO_TREND_COUNTRIES=gb,au,ca

# 主市场（trend_gap 以此为排名基准；get_settings().default_country 与之对齐）
ASO_PRIMARY_COUNTRY=us

# ----- 采集速率与限制 -----
RATE_LIMIT_SLEEP=0.5
AUTOCOMPLETE_LIMIT=20
ITUNES_LIMIT=10

# 排名历史 JSON；Docker 部署 aso-service 时建议在 aso-service/.env 中设为 /data/rank_history.json
RANK_HISTORY_PATH=rank_history.json

# 可选：额外 JSON 覆盖默认（浅层合并）
# ASO_CONFIG_JSON=config.json

# ----- 兼容：仅当未设置 ASO_PRIMARY_COUNTRY 时作为主市场回退 -----
# COUNTRY=us

# =============================================================================
# 以下变量供 aso-service 使用（可复制到 aso-service/.env）
# =============================================================================

# API_KEY=替换为随机32位字符串
# ANTHROPIC_API_KEY=替换为你的Claude API Key

# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_USER=aso
# MYSQL_PASSWORD=替换为强密码
# MYSQL_ROOT_PASSWORD=替换为Root强密码
# MYSQL_DB=aso_db
