# ========== 采集配置 ==========
ASO_PRIMARY_COUNTRY=us
ASO_SCAN_COUNTRIES=us,gb,au,ca
ASO_TREND_COUNTRIES=gb,au,ca
RATE_LIMIT_SLEEP=0.5
AUTOCOMPLETE_LIMIT=20
ITUNES_LIMIT=10
RANK_HISTORY_PATH=/data/rank_history.json

# ========== 服务配置 ==========
API_KEY=replace_with_random_32_char_string
ANTHROPIC_API_KEY=replace_with_your_claude_api_key

# ========== MySQL 8.0 ==========
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=aso
MYSQL_PASSWORD=replace_with_strong_password
MYSQL_ROOT_PASSWORD=replace_with_root_password
MYSQL_DB=aso_db

# ========== 新增数据源配置 ==========
# Google Play
GPLAY_DEFAULT_LANG=en

# Google Trends（pytrends）
TRENDS_TIMEFRAME=today 3-m
TRENDS_SLEEP=1.0

# Reddit API（https://www.reddit.com/prefs/apps 申请）
REDDIT_CLIENT_ID=替换为你的client_id
REDDIT_CLIENT_SECRET=替换为你的client_secret
REDDIT_USER_AGENT=aso-keyword-engine/1.0

# 功能开关（true/false，false时跳过该数据源）
ENABLE_GPLAY=true
ENABLE_TRENDS=true
ENABLE_REDDIT=false
