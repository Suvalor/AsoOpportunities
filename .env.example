# ========== 采集配置 ==========
ASO_PRIMARY_COUNTRY=us
ASO_SCAN_COUNTRIES=us,gb,au,ca
ASO_TREND_COUNTRIES=gb,au,ca
RATE_LIMIT_SLEEP=0.5
AUTOCOMPLETE_LIMIT=20
ITUNES_LIMIT=10
RANK_HISTORY_PATH=/data/rank_history.json

# ========== 服务配置 ==========
API_KEY=replace_with_random_32_char_string
ANTHROPIC_API_KEY=替换为你的Claude API Key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VERSION=2023-06-01

# ========== MySQL 8.0（外部实例；docker-compose 不再内置数据库）==========
# 数据库在宿主机：Docker Desktop 可用 host.docker.internal；compose 已配 extra_hosts 供 Linux 解析
# 数据库在云/RDS：填写实际主机名
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=aso
MYSQL_PASSWORD=replace_with_strong_password
MYSQL_DB=aso_db
# 启动时若库未就绪，按次数重试（避免 uvicorn 立刻退出）
MYSQL_INIT_MAX_RETRIES=30
MYSQL_INIT_RETRY_SLEEP_SEC=2

# ========== 新增数据源配置 ==========
# Google Play
GPLAY_DEFAULT_LANG=en

# Google Trends（pytrends）
TRENDS_TIMEFRAME=today 3-m
TRENDS_SLEEP=1.0

# Reddit API（https://www.reddit.com/prefs/apps 申请）
REDDIT_CLIENT_ID=替换为你的client_id
REDDIT_CLIENT_SECRET=替换为你的client_secret
REDDIT_USER_AGENT=aso-keyword-engine/1.0

# 功能开关（true/false，false时跳过该数据源）
ENABLE_GPLAY=true
ENABLE_TRENDS=true
ENABLE_REDDIT=false

# ========== 报告生成触发阈值 ==========
REPORT_MIN_NEW_GOLD=3
REPORT_MIN_SCORE_DELTA=80
REPORT_MIN_KEYWORD_CHANGE=10
REPORT_COOLDOWN_HOURS=20
