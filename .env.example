# ========== 采集与排名历史（CLI 与 aso-service 共用）==========
# 默认国家/区域（也可用 COUNTRY）
ASO_DEFAULT_COUNTRY=us
RATE_LIMIT_SLEEP=0.5
AUTOCOMPLETE_LIMIT=20
ITUNES_LIMIT=10
# CLI 默认 rank_history.json；Docker 建议在 aso-service/.env 中设为 /data/rank_history.json
RANK_HISTORY_PATH=rank_history.json
# 可选：额外 JSON 覆盖默认（浅层合并），路径可改
# ASO_CONFIG_JSON=config.json

# ========== 仅 aso-service（复制到 aso-service/.env 并填写）==========
# API_KEY=替换为随机32位字符串
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_USER=aso
# MYSQL_PASSWORD=替换为强密码
# MYSQL_ROOT_PASSWORD=替换为Root强密码
# MYSQL_DB=aso_db
