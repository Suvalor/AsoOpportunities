# =============================================================================
# aso-service 运行时环境（docker-compose 通过 env_file 加载）
# =============================================================================

API_KEY=替换为随机32位字符串
ANTHROPIC_API_KEY=替换为你的Claude API Key

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=aso
MYSQL_PASSWORD=替换为强密码
MYSQL_ROOT_PASSWORD=替换为Root强密码
MYSQL_DB=aso_db

RANK_HISTORY_PATH=/data/rank_history.json

# ----- 多国家扫描（与 aso_core.scanner 一致）-----
ASO_SCAN_COUNTRIES=us,gb,au,ca,cn
ASO_TREND_COUNTRIES=gb,au,ca,cn
ASO_PRIMARY_COUNTRY=us,cn

RATE_LIMIT_SLEEP=0.5
AUTOCOMPLETE_LIMIT=20
ITUNES_LIMIT=10
